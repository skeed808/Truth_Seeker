# ════════════════════════════════════════════
# Truth Seeker — Environment Configuration
# ════════════════════════════════════════════
#
# Copy this file to backend/.env and fill in your values.
# The backend loads this automatically via python-dotenv.

# ── Brave Search API (optional but recommended) ──────────
# Get a free key at: https://api.search.brave.com
# Free tier: 2,000 queries/month
# Without this key, only DuckDuckGo results are returned.
BRAVE_API_KEY=

# ── Server settings (optional overrides) ─────────────────
# HOST=0.0.0.0
# PORT=8000
